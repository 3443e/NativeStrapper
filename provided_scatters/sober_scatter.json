{
  "Required": ["echo", "cat", "grep", "head", "tail", "curl"],
  "Platform": ["Linux"],
  "ScatterTitle": "Sober - A roblox runtime for linux.",
  "RobloxURIs": ["roblox", "roblox-player"],
  "RobloxRunCommand": "flatpak run org.vinegarhq.Sober %u",
  "AppDataDirectories": [
    {"path": "/home/%user/.var/app/org.vinegarhq.Sober/data/sober/appData", "label": "Sober"}
  ],
  "BootstrapDownload": {
    "InitCommands": [
      {"system": "curl -s 'https://sober.vinegarhq.org/app' | grep -oE 's[0-9]+-[0-9]+-x86_64-gnu' | tail -1", "token": "soberlatest"}
    ],
    "CurrentVersion": [{
      "system": "strings /home/%user/.var/app/org.vinegarhq.Sober/data/sober/packages/x86_64/com.roblox.client/base.apk | grep -Eo '[0-9]{1,3}\\.[0-9]{1,4}\\.[0-9]{1,4}' | awk -F. '$2 > 700' | tail -1",
      "token": "currentver"
    }],
    "LatestVersion": [{
        "url": "https://apkpure.com/roblox-android-2025/com.roblox.client",
        "token": "latestver",
        "file": "/tmp/apkpure-out.out",
        "system": "cat /tmp/apkpure-out.out | grep -oP '[\\d]+\\.[\\d]+\\.[\\d]+' | head -1"
    }],
    "PreDownloadCommands": [
      {"system": "curl -s --http2 -X GET \"https://sober.vinegarhq.org/update\" -H \"accept: */*\" -H \"sober_version: %soberlatest\" | grep -oP '\\\"base\\.apk\\\":\\\"\\K[^\\\"]+'", "token": "baseapkurl"},
      {"system": "curl -s --http2 -X GET \"https://sober.vinegarhq.org/update\" -H \"accept: */*\" -H \"sober_version: %soberlatest\" | jq -r '.urls[\"split_config.x86_64.apk\"]'", "token": "splitapkurl"}
    ],
    "Download": [
      {"url": "%baseapkurl", "out": "/home/%user/.var/app/org.vinegarhq.Sober/data/sober/packages/x86_64/com.roblox.client/base.apk"},
      {"url": "%splitapkurl", "out": "/home/%user/.var/app/org.vinegarhq.Sober/data/sober/packages/x86_64/com.roblox.client/split_config.x86_64.apk"}
    ]
  }
}