{
    "ScatterTitle": "Roblox - Windows",
    "Platform": ["Windows"],
    "RobloxURIs": ["roblox", "roblox-player"],
    "RobloxRunCommand": "%localappdata\\Roblox\\Versions\\%currentversion\\RobloxPlayerBeta.exe %u",
    "AppDataDirectories": [
        {"path": "%localappdata\\Roblox\\Versions\\%currentversion", "label": "Roblox"}
    ],
    "BootstrapDownload": {
        "Type": "RobloxWindows",
        "CurrentVersion": [
            {"system": "type %localappdata\\Roblox\\Versions\\currentversion.txt", "token": "currentversion"}
        ],
        "LatestVersion": [
            {
                "url": "https://clientsettingscdn.roblox.com/v2/client-version/WindowsPlayer/channel/%CURRENTCHANNEL",
                "token": "versioninfo",
                "jsonkey": "clientVersionUpload",
                "resulttoken": "latestversionguid"
            }
        ],
        "Download": [
            {
                "manifest": "https://setup.rbxcdn.com/%latestversionguid-rbxPkgManifest.txt",
                "base_url": "https://setup.rbxcdn.com/%latestversionguid-",
                "out": "%localappdata\\Roblox\\Versions\\%latestversionguid",
                "verify_md5": true
            }
        ],
        "AfterDownload": [
            "cmd /c echo %latestversionguid > %localappdata\\Roblox\\Versions\\currentversion.txt"
        ]
    }
}